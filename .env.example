# Copy to .env and fill in real values.
# Source with: export $(grep -v '^#' .env | xargs)

# ── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection URL
BAMBU_DB_URL=postgresql://bambu:bambu_dev_pass@localhost:5432/bambu_tracker

# Flask session secret key (min 32 random characters)
BAMBU_SECRET_KEY=change-me-to-a-random-32-char-secret

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# Set BAMBU_CREATE_ADMIN=1 on first start only, then set back to 0.
BAMBU_CREATE_ADMIN=0
BAMBU_ADMIN_USER=admin
BAMBU_ADMIN_EMAIL=admin@your-domain.local
BAMBU_ADMIN_PASS=change-me-immediately

# ── Optional ──────────────────────────────────────────────────────────────────
# Path to config.yaml (defaults to ./config.yaml)
# BAMBU_CONFIG=/etc/bambu-tracker/config.yaml

# Gunicorn workers (rule of thumb: 2*CPU+1)
# GUNICORN_WORKERS=4
