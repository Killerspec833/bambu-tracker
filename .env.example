# Bambu Tracker — environment variable template
# Copy to .env and fill in real values before running docker compose up.
#
# Generate BAMBU_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL password — used by the db service and BAMBU_DB_URL
POSTGRES_PASSWORD=change_me_strong_password

# Flask session secret key (min 32 random characters)
BAMBU_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# Set BAMBU_CREATE_ADMIN=1 on first start only, then set back to 0 (or remove).
BAMBU_CREATE_ADMIN=1
BAMBU_ADMIN_USER=admin
BAMBU_ADMIN_EMAIL=admin@your-domain.local
BAMBU_ADMIN_PASS=change-me-immediately

# ── MQTT / printer config ─────────────────────────────────────────────────────
# Absolute path to your config.yaml on the host.
# When set, the container copies it in and enables live MQTT printer monitoring.
# When not set (default /dev/null), the app runs in web-only/inventory mode.
# CONFIG_PATH=/home/youruser/bambu-tracker/config.yaml

# Absolute path to your Bambu Cloud token file on the host.
# Required when CONFIG_PATH is set — the container reads this for MQTT auth.
# Generate/refresh with: python3 get_token.py  OR  the Printers → Refresh Token button.
# TOKEN_FILE=/home/youruser/.bambu_token

# ── Optional overrides ────────────────────────────────────────────────────────

# Postgres username (defaults to "bambu")
# POSTGRES_USER=bambu

# Redis rate-limiter URI — defaults to redis://redis:6379 in docker compose.
# Override if you use an external Redis instance.
# RATELIMIT_STORAGE_URI=redis://your-redis-host:6379

# Direct DB URL override (skips POSTGRES_PASSWORD above; useful outside Docker)
# BAMBU_DB_URL=postgresql://bambu:bambu_dev_pass@localhost:5432/bambu_tracker
