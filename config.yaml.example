# Bambu Filament Tracker — Configuration
# Copy this file to config.yaml and fill in your credentials.
#
# Printer credentials:
#   serial      — printed on the label, visible in Bambu Studio
#   access_token — Bambu Studio → Device → select printer → gear icon → Access Code
#
# Database:
#   Requires PostgreSQL. Recommended: Supabase (free tier), Render Postgres, or self-hosted.
#   Set BAMBU_DB_URL env var to override the url here.
#
# After editing, run:
#   alembic upgrade head           ← create/migrate DB tables
#   python run.py --create-admin   ← create the first admin user

database:
  url: "postgresql://user:password@localhost:5432/bambu_tracker"
  # or: "postgresql://user:password@db.supabase.co:5432/postgres"

printers:
  - name: "P1S-1"
    model: P1S
    serial: "YOUR_SERIAL_HERE"      # e.g. 01P00A123456789
    access_token: "YOUR_TOKEN_HERE" # 8-character alphanumeric access code
    region: us  # us | eu | ap

  - name: "P1S-2"
    model: P1S
    serial: "YOUR_SERIAL_HERE"
    access_token: "YOUR_TOKEN_HERE"
    region: us

  - name: "A1-1"
    model: A1
    serial: "YOUR_SERIAL_HERE"
    access_token: "YOUR_TOKEN_HERE"
    region: us

alerts:
  desktop: true           # use notify-send (requires libnotify-bin on Linux)
  openclaw: true          # use: openclaw system event --text "..." --mode now
  low_stock_grams: 50     # alert when spool < this many grams remaining
  pre_print_check: true   # alert before print if stock insufficient

web_ui:
  port: 7070
  host: "0.0.0.0"
  secret_key: "change-me-to-a-random-secret-min-32-chars"

cloud_auth:
  username: "your@email.com"        # Bambu Lab account email
  token_file: "~/.bambu_token"      # file containing your Bambu Cloud token

# Environment variable overrides (useful for containers / CI):
#   BAMBU_DB_URL      — overrides database.url
#   BAMBU_SECRET_KEY  — overrides web_ui.secret_key
